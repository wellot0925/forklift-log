rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isApproved() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && myProfile().status == 'approved';
    }

    function isAdmin() {
      return isApproved() && myProfile().role == 'admin';
    }

    // 사용자 프로필: 본인 또는 관리자만 조회 가능.
    // 생성은 본인만, 반드시 status=pending, role=user로만 가입 가능(자가 승인/자가 관리자화 차단).
    // 이후 상태/역할 변경은 관리자만 가능 — 일반 사용자는 자기 문서를 수정할 수 없음.
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // 관리자는 전체 목록 조회 가능. 그 외(로그인 전 포함)엔 회원가입 시 아이디 중복
      // 체크용으로 최대 1건만 반환하는 좁은 쿼리만 허용 — 전체 목록 열람은 막힘
      allow list: if isAdmin() || request.query.limit <= 1;
      allow create: if isSignedIn() && request.auth.uid == userId
        && request.resource.data.status == 'pending'
        && request.resource.data.role == 'user'
        && request.resource.data.username is string
        && request.resource.data.name is string;
      // 관리자는 자유롭게 수정 가능. 그 외엔 본인만, 그것도 아래 두 좁은 경우만 허용:
      // ① 거절(rejected)당한 본인이 로그인 시 재승인 요청을 위해 status를 pending으로만 되돌림
      // ② 비밀번호 찾기용 이메일 등록/자가치유 동기화/pendingEmail 승격 — email, pendingEmail
      //    필드만 바꿀 수 있음 (registerRecoveryEmail의 pendingEmail 기록과, login()의 2차
      //    시도 성공 시 pendingEmail -> email 승격이 이 규칙으로 커버됨)
      allow update: if isAdmin() || (
        isSignedIn() && request.auth.uid == userId && (
          (resource.data.status == 'rejected' &&
            request.resource.data.status == 'pending' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email', 'pendingEmail'])
        )
      );
      allow delete: if false;
    }

    // 관리자 삭제 비밀번호 등 앱 설정: 조회는 승인된 사용자 전체(삭제 시 클라이언트에서
    // 비밀번호 비교에 필요) 허용하되, 변경은 관리자만 가능
    match /settings/{docId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // 작업일지 / 정비팁: 승인된 사용자만 읽고 쓸 수 있음
    match /records/{recordId} {
      allow read, write: if isApproved();
    }
    match /tips/{tipId} {
      allow read, write: if isApproved();
    }
  }
}
