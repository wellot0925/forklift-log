rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isApproved() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && myProfile().status == 'approved';
    }

    function isAdmin() {
      return isApproved() && myProfile().role == 'admin';
    }

    // 사용자 프로필: 본인 또는 관리자만 조회 가능.
    // 생성은 본인만, 반드시 status=pending, role=user로만 가입 가능(자가 승인/자가 관리자화 차단).
    // 이후 상태/역할 변경은 관리자만 가능 — 일반 사용자는 자기 문서를 수정할 수 없음.
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // 관리자는 전체 목록 조회 가능. 그 외(로그인 전 포함)엔 회원가입 시 아이디 중복
      // 체크용으로 최대 1건만 반환하는 좁은 쿼리만 허용 — 전체 목록 열람은 막힘
      allow list: if isAdmin() || request.query.limit <= 1;
      allow create: if isSignedIn() && request.auth.uid == userId
        && request.resource.data.status == 'pending'
        && request.resource.data.role == 'user'
        && request.resource.data.username is string
        && request.resource.data.name is string;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // 관리자 삭제 비밀번호 등 앱 설정: 승인된 사용자만 읽고 쓸 수 있음
    match /settings/{docId} {
      allow read, write: if isApproved();
    }

    // 작업일지 / 정비팁: 승인된 사용자만 읽고 쓸 수 있음
    match /records/{recordId} {
      allow read, write: if isApproved();
    }
    match /tips/{tipId} {
      allow read, write: if isApproved();
    }
  }
}
